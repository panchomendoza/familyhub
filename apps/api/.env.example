# ── NUNCA subir el .env real a git ─────────────────────────────────────────
# Copiar como .env y completar con valores reales
# Generar secretos: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Base de datos (Supabase — usar Transaction Pooler en producción) ─────────
# Ir a: Supabase > Settings > Database > Connection string > Transaction pooler
# Asegurarse de agregar ?pgbouncer=true&sslmode=require al final
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar valores únicos para producción (NO reutilizar los de desarrollo)
JWT_ACCESS_SECRET=REEMPLAZAR_CON_64_BYTES_HEX
JWT_REFRESH_SECRET=REEMPLAZAR_CON_64_BYTES_HEX_DIFERENTE
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=1d
SESSION_MAX_EXPIRES=30m

# ── CSRF ─────────────────────────────────────────────────────────────────────
CSRF_SECRET=REEMPLAZAR_CON_64_BYTES_HEX_DIFERENTE

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console > Credenciales > OAuth 2.0
# Orígenes JS autorizados: https://tu-dominio.com
# URIs de redirección: (no aplica, usamos popup flow)
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
# resend.com > API Keys + verificar dominio propio para FROM_EMAIL personalizado
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@tu-dominio.com
RESEND_FROM_NAME=FamilyHub
SEND_EMAILS=true

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL exacta del frontend en Vercel (sin trailing slash)
FRONTEND_URL=https://familyhub.vercel.app

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
