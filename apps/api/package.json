{
  "name": "@familyhub/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":        "tsx watch src/index.ts",
    "dev:start":  "tsx src/index.ts",
    "build":      "tsc",
    "start":      "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint":       "eslint src --ext ts",
    "db:push":      "prisma db push",
    "db:push:prod": "dotenv -e .env.production -- prisma db push",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio",
    "db:studio:prod": "dotenv -e .env.production -- prisma studio",
    "db:seed":      "tsx src/lib/seed.ts",
    "test":         "vitest run",
    "test:watch":   "vitest"
  },
  "dependencies": {
    "@familyhub/types":    "workspace:*",
    "hono":                "^4.4.0",
    "@hono/node-server":   "^1.11.1",
    "@prisma/client":      "^5.15.0",
    "better-auth":         "^0.4.0",
    "resend":              "^3.2.0",
    "@react-email/components": "^0.0.36",
    "react":               "^18.3.1",
    "react-dom":           "^18.3.1",
    "zod":                 "^3.23.8",
    "bcryptjs":            "^2.4.3",
    "jsonwebtoken":        "^9.0.2",
    "nanoid":              "^5.0.7",
    "helmet":              "^7.1.0",
    "dotenv":              "^16.4.5"
  },
  "devDependencies": {
    "@types/bcryptjs":      "^2.4.6",
    "@types/jsonwebtoken":  "^9.0.6",
    "@types/node":          "^20.14.2",
    "@types/react":         "^18.3.3",
    "@types/react-dom":     "^18.3.0",
    "prisma":               "^5.15.0",
    "dotenv-cli":           "^7.4.2",
    "tsx":                  "^4.15.6",
    "typescript":           "^5.4.5",
    "vitest":               "^1.6.0"
  }
}
