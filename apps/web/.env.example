# ── NUNCA subir .env real a git ──────────────────────────────────────────────
# Desarrollo: copiar como .env.local
# Producción: configurar como variables de entorno en Vercel (sin prefijo VITE_)

# URL completa de la API backend (Railway en producción, sin trailing slash)
# Desarrollo:   http://localhost:4000
# Producción:   https://familyhub-api.up.railway.app  (o tu dominio personalizado)
VITE_API_URL=http://localhost:4000

# Google OAuth Client ID (solo el ID público — NUNCA el secret aquí)
VITE_GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
